{
  "name": "notion-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first, encrypted, Notion-like desktop app (Tauri + React + Yjs + SQLCipher).",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
